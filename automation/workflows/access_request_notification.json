            {
              "name": "company",
              "value": "={{ $json.record.company || 'Não especificado' }}"
            },
            {
              "name": "plan",
              "value": "={{ $json.record.plan }}"
            },
            {
              "name": "message",
              "value": "={{ $json.record.message || 'Sem mensagem' }}"
            }
          ]
        },
        "options": {}
